{
  "name": "steelyard-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript SDK for defining read-side commerce once and serving it over MCP, ACP, and UCP.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --concurrency=1",
    "typecheck": "turbo run typecheck",
    "validate-examples": "tsx scripts/validate-examples.mts",
    "smoke": "turbo run smoke",
    "verify": "pnpm --filter @steelyard-dev/protocol regen:acp-types && git diff --exit-code -- packages/protocol/src/acp/types.generated.ts && tsx packages/verify/src/cli.ts",
    "lint": "biome lint --files-ignore-unknown=true .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.9",
    "json-schema-to-typescript": "^15.0.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
