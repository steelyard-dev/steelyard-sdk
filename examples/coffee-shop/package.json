{
  "name": "@steelyard/example-coffee-shop",
  "version": "0.2.0",
  "private": true,
  "description": "Coffee shop example merchant for Steelyard.",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "buy:real": "tsx src/buy-real.ts",
    "buy:wallet": "tsx src/buy-with-wallet.ts",
    "buy:primitives": "tsx src/buy-with-primitives.ts",
    "buy:primitives:v03": "tsx src/buy-with-primitives-v03.ts",
    "dev": "tsx src/index.ts",
    "scan:routes": "tsx scripts/scan-routes.ts",
    "smoke:ap2": "tsx scripts/smoke-ap2.ts",
    "smoke:bearer": "tsx scripts/smoke-bearer.ts",
    "smoke:vanilla-ucp": "tsx scripts/smoke-vanilla-ucp.ts",
    "smoke:well-known": "tsx scripts/smoke-well-known.ts",
    "smoke:stripe": "tsx scripts/smoke-stripe.ts",
    "smoke:ucp:dual": "tsx scripts/smoke-dual-ucp.ts",
    "smoke:stripe:ucp": "tsx scripts/smoke-stripe-ucp.ts",
    "smoke:stripe:acp": "tsx scripts/smoke-stripe-acp.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "tsx": "pnpm -w build && tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@steelyard/buyer": "workspace:*",
    "@steelyard/core": "workspace:*",
    "@steelyard/merchant": "workspace:*",
    "@steelyard/protocol": "workspace:*",
    "@steelyard/stripe": "workspace:*"
  }
}
