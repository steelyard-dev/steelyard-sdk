{
  "name": "@steelyard/client",
  "version": "0.1.0",
  "description": "Buyer SDK for connecting to Steelyard merchants over MCP, ACP, or UCP.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@steelyard/core": "workspace:*"
  },
  "devDependencies": {
    "@steelyard/acp": "workspace:*",
    "@steelyard/mcp": "workspace:*",
    "@steelyard/ucp": "workspace:*"
  }
}
