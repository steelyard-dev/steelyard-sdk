{
  "name": "@steelyard/merchant",
  "version": "0.2.0",
  "description": "Merchant-side primitives for Steelyard: policy engine and (future) trust controls. Subpath imports.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./checkout": {
      "types": "./dist/checkout/index.d.ts",
      "import": "./dist/checkout/index.js",
      "require": "./dist/checkout/index.cjs"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js",
      "require": "./dist/policy/index.cjs"
    },
    "./psp": {
      "types": "./dist/psp/index.d.ts",
      "import": "./dist/psp/index.js",
      "require": "./dist/psp/index.cjs"
    },
    "./mandate": {
      "types": "./dist/mandate/index.d.ts",
      "import": "./dist/mandate/index.js",
      "require": "./dist/mandate/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sd-jwt/core": "^0.19.0",
    "@sd-jwt/sd-jwt-vc": "^0.19.0",
    "@steelyard/core": "workspace:^",
    "@steelyard/psp": "workspace:^",
    "@steelyard/protocol": "workspace:^",
    "@steelyard/ucp-signing": "workspace:^",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4"
  }
}
