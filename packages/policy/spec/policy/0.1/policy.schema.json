{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steelyard.dev/schemas/policy/0.1.json",
  "title": "Steelyard Policy v0.1",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "enum": ["2026-06-27"] },
    "trusted_domains": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "format": "hostname" }
      }
    },
    "blocked_domains": {
      "type": "array",
      "items": { "type": "string", "format": "hostname" }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["name", "do"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "do": { "enum": ["allow", "deny", "require_approval"] },
        "rail": { "enum": ["virtual_card"] },
        "when": { "$ref": "#/$defs/when" },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "per_day_usd": { "type": "number", "minimum": 0 },
            "per_day_count": { "type": "integer", "minimum": 0 },
            "per_purchase_usd": { "type": "number", "minimum": 0 }
          }
        },
        "approval": {
          "type": "object",
          "required": ["who", "channel", "expires_in"],
          "additionalProperties": false,
          "properties": {
            "who": { "const": "user" },
            "channel": { "const": "webhook" },
            "expires_in": { "type": "string", "pattern": "^[0-9]+(ms|s|m|h)$" },
            "include_in_prompt": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "when": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "merchant_domain_in": { "type": "string", "minLength": 1 },
        "amount_usd": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "min": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 }
          }
        },
        "type": {
          "oneOf": [
            { "$ref": "#/$defs/intent_type" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/intent_type" }
            }
          ]
        },
        "cart_contains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "merchant_supports": { "enum": ["ucp_acp"] },
        "merchant_signature": { "enum": ["verified"] },
        "tls": { "enum": ["required"] }
      }
    },
    "intent_type": {
      "enum": ["one_time", "subscription", "mandate", "installment"]
    }
  }
}
