{
  "name": "@steelyard-dev/protocol",
  "version": "0.11.0",
  "description": "Protocol adapters for Steelyard: MCP, ACP, UCP. Subpath imports per protocol.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./commerce-manifest": {
      "types": "./dist/commerce-manifest/index.d.ts",
      "import": "./dist/commerce-manifest/index.js",
      "require": "./dist/commerce-manifest/index.cjs"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs"
    },
    "./acp": {
      "types": "./dist/acp/index.d.ts",
      "import": "./dist/acp/index.js",
      "require": "./dist/acp/index.cjs"
    },
    "./acp/checkout": {
      "types": "./dist/acp/checkout.d.ts",
      "import": "./dist/acp/checkout.js",
      "require": "./dist/acp/checkout.cjs"
    },
    "./ucp": {
      "types": "./dist/ucp/index.d.ts",
      "import": "./dist/ucp/index.js",
      "require": "./dist/ucp/index.cjs"
    },
    "./ucp/checkout": {
      "types": "./dist/ucp/checkout.d.ts",
      "import": "./dist/ucp/checkout.js",
      "require": "./dist/ucp/checkout.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/copy-specs.mjs",
    "regen:acp-types": "node scripts/generate-acp-types.mjs",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@steelyard-dev/core": "workspace:^",
    "@steelyard-dev/ucp-signing": "workspace:^",
    "@ucp-js/sdk": "^0.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  },
  "private": true
}
