{
  "name": "@steelyard-dev/buyer",
  "version": "0.11.0",
  "description": "Buyer-side primitives for Steelyard: unified client, policy engine, local vault. Subpath imports.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/wallet/index.d.ts",
      "import": "./dist/wallet/index.js",
      "require": "./dist/wallet/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./client/acp": {
      "types": "./dist/client/acp.d.ts",
      "import": "./dist/client/acp.js",
      "require": "./dist/client/acp.cjs"
    },
    "./client/ucp": {
      "types": "./dist/client/ucp.d.ts",
      "import": "./dist/client/ucp.js",
      "require": "./dist/client/ucp.cjs"
    },
    "./vault": {
      "types": "./dist/vault/index.d.ts",
      "import": "./dist/vault/index.js",
      "require": "./dist/vault/index.cjs"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js",
      "require": "./dist/policy/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^1.8.0",
    "@sd-jwt/core": "^0.19.0",
    "@sd-jwt/sd-jwt-vc": "^0.19.0",
    "@steelyard-dev/core": "workspace:^",
    "@steelyard-dev/protocol": "workspace:^",
    "@steelyard-dev/ucp-signing": "workspace:^",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@steelyard-dev/merchant": "workspace:^",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4"
  },
  "private": true
}
