{
  "name": "@steelyard/acp",
  "version": "0.1.0",
  "description": "ACP feed adapter for Steelyard read-side commerce manifests.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@steelyard/core": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
