{
  "name": "steelyard",
  "version": "0.2.0",
  "description": "The Steelyard SDK front door: define commerce once, serve it over commerce.json, HTTP, MCP, ACP, and UCP, and let buyers complete agentic purchases.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@steelyard/buyer": "workspace:^",
    "@steelyard/core": "workspace:^",
    "@steelyard/merchant": "workspace:^",
    "@steelyard/protocol": "workspace:^",
    "@steelyard/stripe": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.9"
  }
}
