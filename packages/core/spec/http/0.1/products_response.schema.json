{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steelyard.dev/schemas/http/0.1/products_response.json",
  "title": "Steelyard HTTP Products Response",
  "type": "object",
  "required": ["products", "total", "offset", "limit"],
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "$ref": "https://steelyard.dev/schemas/commerce-manifest/0.1.json#/$defs/offer"
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "offset": {
      "type": "integer",
      "minimum": 0
    },
    "limit": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    }
  },
  "additionalProperties": true
}
