{
  "name": "@steelyard/core",
  "version": "0.2.0",
  "description": "Core read-side commerce manifest, validation, and types for Steelyard.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./policy-yaml": {
      "types": "./dist/policy-yaml/index.d.ts",
      "import": "./dist/policy-yaml/index.js",
      "require": "./dist/policy-yaml/index.cjs"
    },
    "./order-state": {
      "types": "./dist/order-state.d.ts",
      "import": "./dist/order-state.js",
      "require": "./dist/order-state.cjs"
    },
    "./idempotency": {
      "types": "./dist/idempotency/index.d.ts",
      "import": "./dist/idempotency/index.js",
      "require": "./dist/idempotency/index.cjs"
    },
    "./purchase": {
      "types": "./dist/purchase.d.ts",
      "import": "./dist/purchase.js",
      "require": "./dist/purchase.cjs"
    }
  },
  "files": [
    "dist",
    "PORT_AUDIT.md"
  ],
  "scripts": {
    "build": "node scripts/generate-commerce-types.mjs --check && tsup && node scripts/copy-specs.mjs",
    "generate:types": "node scripts/generate-commerce-types.mjs",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "canonicalize": "^3.0.0",
    "uuidv7": "^1.2.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  }
}
