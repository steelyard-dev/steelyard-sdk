{
  "name": "@steelyard-dev/agent",
  "version": "0.11.0",
  "description": "CLI explorer agent for Steelyard merchants.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "steelyard-agent": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@steelyard-dev/buyer": "workspace:^",
    "@steelyard-dev/core": "workspace:^"
  },
  "private": true
}
